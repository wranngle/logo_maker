# >>> dotfiles-managed gitignore (do not edit between markers) >>>
# Generated by .dotfiles.sh — edits between markers are overwritten on next deploy.
# Hand-edit OUTSIDE these markers for project-specific rules.

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets
.env
.env.*
!.env.example
!.env.template
*.pem
*.key

# Agent / AI scratch
.claude/
.codex/
.gemini/
.symphony/workspaces/
.assessment.cache

# Crash dumps & cores
*.dump
*.core
core.*
*.heapsnapshot
hs_err_pid*.log
erl_crash.dump

# Logs
*.log
logs/*.jsonl
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Generic build/cache/scratch
.cache/
tmp/
temp/
old/*
!old/.gitkeep
coverage/
*.bak
*.orig
*.rej

# Common build/dep dirs (covered for language=NONE; redundant when a template adds them)
node_modules/
__pycache__/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
target/
dist/
build/
out/
# <<< dotfiles-managed gitignore <<<
*.png
*.webp
output/
